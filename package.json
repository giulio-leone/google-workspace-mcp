{
  "name": "@aaronsb/google-workspace-mcp",
  "version": "2.3.0",
  "description": "MCP server for Google Workspace with progressive context disclosure and multi-account orchestration",
  "repository": {
    "type": "git",
    "url": "https://github.com/aaronsb/google-workspace-mcp"
  },
  "type": "module",
  "bin": {
    "google-workspace-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc --skipLibCheck && cp src/factory/manifest.yaml build/factory/",
    "type-check": "tsc --noEmit --skipLibCheck",
    "lint": "eslint \"src/**/*.ts\"",
    "watch": "tsc --watch --skipLibCheck",
    "test:gmail-watch": "node ./scripts/test-gmail-watch.mjs",
    "test": "jest --config jest.config.cjs --runInBand",
    "test:watch": "jest --config jest.config.cjs --watch --runInBand"
  },
  "dependencies": {
    "@googleworkspace/cli": "^0.22.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5"
  }
}
